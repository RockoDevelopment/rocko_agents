{
  "schema_version": "2.0",
  "project": {
    "id": "the_paper_team",
    "name": "ThePaperTeam",
    "display_name": "The Paper Team Agency",
    "description": "Multi-agent algorithmic trading firm operating on Solana DEX",
    "version": "1.0.0",
    "root_path": "C:\\Users\\brian\\Documents\\ThePaperTeam",
    "environment_file": ".env",
    "created": "2025-04-20",
    "tags": [
      "trading",
      "solana",
      "dex",
      "algo"
    ]
  },
  "model": {
    "default_provider": "anthropic",
    "default_model": "claude-sonnet-4-20250514",
    "fallback_model": "claude-haiku-4-5-20251001",
    "providers": {
      "anthropic": {
        "type": "anthropic",
        "api_base": "https://api.anthropic.com/v1",
        "api_key_env": "ANTHROPIC_API_KEY",
        "temperature": 0.3,
        "max_tokens": 2000
      }
    }
  },
  "paths": {
    "agents_root": "core\\agents",
    "vault_root": "vault",
    "logs_root": "logs",
    "outputs_root": "outputs",
    "data_root": "data",
    "historical_data": "data\\historical",
    "src_root": "core"
  },
  "databases": {
    "trade_ledger": {
      "type": "json",
      "path": "vault\\trade_ledger.json",
      "description": "All approved and executed trades"
    },
    "rejection_log": {
      "type": "json",
      "path": "vault\\rejection_log.json",
      "description": "All rejected trade attempts with reasons"
    },
    "regime_history": {
      "type": "json",
      "path": "vault\\regime_history.json",
      "description": "Market regime classification history"
    },
    "agent_metrics": {
      "type": "json",
      "path": "vault\\agent_metrics.json",
      "description": "Per-agent performance metrics over time"
    },
    "historical_ohlcv": {
      "type": "csv",
      "path": "data\\historical\\",
      "description": "1-2 years OHLCV per token"
    }
  },
  "vault": {
    "root": "vault",
    "folders": {
      "trades": "vault\\trades",
      "rejections": "vault\\rejections",
      "regime": "vault\\regime",
      "snapshots": "vault\\snapshots"
    },
    "description": "Persistent memory store \u2014 all trade history, rejection logs, regime classifications"
  },
  "env": {
    "required": [
      "ANTHROPIC_API_KEY",
      "NEWS_API_KEY",
      "HELIUS_API_KEY",
      "EXCHANGE_API_KEY"
    ],
    "optional": [
      "LUNAR_CRUSH_KEY",
      "SOLANA_WALLET_KEY",
      "LOG_LEVEL"
    ],
    "env_file": ".env"
  },
  "tools": {
    "filesystem": {
      "enabled": true,
      "allowed_paths": [
        "{{PROJECT_ROOT}}"
      ]
    },
    "web_search": {
      "enabled": true,
      "provider": "anthropic_native"
    },
    "http": {
      "enabled": true
    },
    "shell": {
      "enabled": false
    },
    "sqlite": {
      "enabled": false
    },
    "memory_store": {
      "enabled": true,
      "backend": "local_json",
      "path": "{{PROJECT_ROOT}}\\vault\\"
    }
  },
  "apis": {
    "news_api": {
      "enabled": true,
      "base_url": "https://newsapi.org/v2",
      "auth_type": "api_key",
      "api_key_env": "NEWS_API_KEY",
      "timeout_seconds": 10,
      "retry_count": 3
    },
    "sentiment_feed": {
      "enabled": true,
      "base_url": "https://api.lunarcrush.com/v2",
      "auth_type": "api_key",
      "api_key_env": "LUNAR_CRUSH_KEY",
      "timeout_seconds": 10,
      "retry_count": 2
    },
    "solana_rpc": {
      "enabled": true,
      "base_url": "https://api.mainnet-beta.solana.com",
      "auth_type": "none",
      "timeout_seconds": 15,
      "retry_count": 3
    },
    "helius_api": {
      "enabled": true,
      "base_url": "https://api.helius.xyz/v0",
      "auth_type": "api_key",
      "api_key_env": "HELIUS_API_KEY",
      "timeout_seconds": 10,
      "retry_count": 2
    },
    "dex_screener": {
      "enabled": true,
      "base_url": "https://api.dexscreener.com/latest",
      "auth_type": "none",
      "timeout_seconds": 10,
      "retry_count": 2
    },
    "exchange_api": {
      "enabled": true,
      "base_url": "https://api.exchange.placeholder.com",
      "auth_type": "api_key",
      "api_key_env": "EXCHANGE_API_KEY",
      "timeout_seconds": 15,
      "retry_count": 3
    }
  },
  "executors": {
    "director": {
      "type": "python_module",
      "label": "Director (Debate Layer)",
      "script_path": "core\\agents\\director.py",
      "entry": "run_director",
      "working_dir": "core",
      "env_file": ".env",
      "run_mode": "subprocess"
    },
    "quant_engine": {
      "type": "python_module",
      "label": "Quant Engine",
      "script_path": "core\\agents\\quant.py",
      "entry": "run_quant",
      "working_dir": "core",
      "env_file": ".env",
      "run_mode": "subprocess"
    },
    "risk_manager": {
      "type": "python_module",
      "label": "Risk Manager",
      "script_path": "core\\agents\\risk_manager.py",
      "entry": "run_risk_manager",
      "working_dir": "core",
      "env_file": ".env",
      "run_mode": "subprocess"
    },
    "execution_engine": {
      "type": "python_module",
      "label": "Execution",
      "script_path": "core\\agents\\execution.py",
      "entry": "run_execution",
      "working_dir": "core",
      "env_file": ".env",
      "run_mode": "subprocess"
    }
  },
  "agents": [
    {
      "id": "ceo_agent",
      "name": "CEO / Director",
      "role": "ceo",
      "type": "prompt",
      "instruction_file": "agents\\ceo_agent\\AGENT.md",
      "model_provider": "anthropic",
      "model_override": "claude-opus-4-20250514",
      "pipeline_step": "ceo_approval",
      "enabled": true,
      "project_tools": [
        "filesystem",
        "memory_store",
        "http"
      ],
      "apis": [
        "exchange_api"
      ],
      "local_code": null,
      "description": "Final approval layer. Controls system posture."
    },
    {
      "id": "news_agent",
      "name": "News & Fundamentals Analyst",
      "role": "analyst",
      "type": "prompt",
      "instruction_file": "agents\\news_agent\\AGENT.md",
      "model_provider": "anthropic",
      "model_override": null,
      "pipeline_step": "news_context",
      "enabled": true,
      "project_tools": [
        "web_search",
        "http"
      ],
      "apis": [
        "news_api",
        "sentiment_feed"
      ],
      "local_code": null,
      "description": "Macro events, crypto news, social sentiment context."
    },
    {
      "id": "onchain_agent",
      "name": "On-Chain Forensics Analyst",
      "role": "analyst",
      "type": "prompt",
      "instruction_file": "agents\\onchain_agent\\AGENT.md",
      "model_provider": "anthropic",
      "model_override": null,
      "pipeline_step": "onchain_scan",
      "enabled": true,
      "project_tools": [
        "http"
      ],
      "apis": [
        "solana_rpc",
        "helius_api",
        "dex_screener"
      ],
      "local_code": null,
      "description": "Liquidity anomalies, whale movements, pool risks on Solana."
    },
    {
      "id": "backtest_agent",
      "name": "Backtesting Engine",
      "role": "engine",
      "type": "hybrid",
      "instruction_file": "agents\\backtest_agent\\AGENT.md",
      "model_provider": "anthropic",
      "model_override": null,
      "pipeline_step": "backtest_validate",
      "enabled": true,
      "project_tools": [
        "filesystem",
        "memory_store"
      ],
      "apis": [],
      "local_code": {
        "type": "python_module",
        "script_path": "core\\quant.py",
        "entry": "run_backtest",
        "working_dir": "core",
        "env_file": ".env",
        "run_mode": "subprocess"
      },
      "description": "Validates trades against historical regimes."
    },
    {
      "id": "portfolio_agent",
      "name": "Portfolio Optimizer",
      "role": "analyst",
      "type": "hybrid",
      "instruction_file": "agents\\portfolio_agent\\AGENT.md",
      "model_provider": "anthropic",
      "model_override": null,
      "pipeline_step": "portfolio_check",
      "enabled": true,
      "project_tools": [
        "filesystem",
        "memory_store"
      ],
      "apis": [
        "exchange_api"
      ],
      "local_code": {
        "type": "python_module",
        "script_path": "core\\risk_manager.py",
        "entry": "run_portfolio_optimizer",
        "working_dir": "core",
        "env_file": ".env",
        "run_mode": "subprocess"
      },
      "description": "Portfolio-level capital control and hedging."
    }
  ],
  "pipeline": {
    "mode": "sequential",
    "on_block": "halt",
    "on_error": "halt_and_log",
    "execution_order": [
      {
        "step_id": "news_context",
        "label": "News & Fundamentals Analyst",
        "type": "agent",
        "agent_id": "news_agent"
      },
      {
        "step_id": "onchain_scan",
        "label": "On-Chain Forensics Analyst",
        "type": "agent",
        "agent_id": "onchain_agent"
      },
      {
        "step_id": "director_debate",
        "label": "Director (Debate Layer)",
        "type": "executor",
        "executor_id": "director"
      },
      {
        "step_id": "quant_calc",
        "label": "Quant Engine",
        "type": "executor",
        "executor_id": "quant_engine"
      },
      {
        "step_id": "backtest_validate",
        "label": "Backtesting Engine",
        "type": "agent",
        "agent_id": "backtest_agent"
      },
      {
        "step_id": "risk_gate",
        "label": "Risk Manager",
        "type": "executor",
        "executor_id": "risk_manager"
      },
      {
        "step_id": "portfolio_check",
        "label": "Portfolio Optimizer",
        "type": "agent",
        "agent_id": "portfolio_agent"
      },
      {
        "step_id": "ceo_approval",
        "label": "CEO Final Approval",
        "type": "agent",
        "agent_id": "ceo_agent",
        "requires_approval": true
      },
      {
        "step_id": "execute_trade",
        "label": "Execution",
        "type": "executor",
        "executor_id": "execution_engine"
      }
    ]
  },
  "logs": {
    "root": "logs",
    "pipeline_log": "logs\\pipeline.log",
    "agent_log": "logs\\agents.log",
    "error_log": "logs\\errors.log",
    "trade_log": "logs\\trades.log",
    "format": "jsonl",
    "rotation": "daily",
    "retain_days": 30
  },
  "validation": {
    "check_agent_files": true,
    "check_executor_paths": true,
    "check_database_paths": true,
    "check_vault_root": true,
    "check_env_vars": true,
    "check_api_reachability": false,
    "fail_mode": "warn"
  }
}