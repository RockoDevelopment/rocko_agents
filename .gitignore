# ── Your personal projects (never commit these) ───────────────────────────────
projects/*/
!projects/.gitkeep
!templates/

# ── Compiled executables (distributed via GitHub Releases, not the repo) ──────
rocko.exe
rocko
*.exe

# ── Runtime data (written by the bridge, machine-specific) ───────────────────
data/
dist/
build/
*.spec.bak
*.spec.tmp

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
.venv/
venv/
env/
.env
.env.*
!.env.example

# ── Secrets — never commit these ─────────────────────────────────────────────
*.key
*.pem
*.secret
secrets.json

# ── Skills cache (fetched from GitHub, machine-specific) ─────────────────────
.rocko_skills/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo